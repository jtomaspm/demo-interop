{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug C# + C (Native Debugger)",
            "type": "cppdbg",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "/usr/bin/dotnet",
            "args": [
                "exec",
                "${workspaceFolder}/src/Demo.Interop.CLI/bin/Debug/net10.0/Demo.Interop.CLI.dll"
            ],
            "cwd": "${workspaceFolder}",
            "environment": [{"name": "PATH", "value": "${env:PATH}"}],
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Enable pending breakpoints for shared library symbols",
                    "text": "set breakpoint pending on",
                    "ignoreFailures": true
                }
            ],
            "sourceFileMap": {
                "src": "${workspaceFolder}/engine/src"
            },
            "additionalSOLibSearchPath": "${workspaceFolder}/engine/bin"
        },
        {
            "name": "Launch C# App (Managed Only)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "/usr/bin/dotnet",
            "args": [
                "exec",
                "${workspaceFolder}/src/Demo.Interop.CLI/bin/Debug/net10.0/Demo.Interop.CLI.dll"
            ],
            "cwd": "${workspaceFolder}",
            "env": {
                "PATH": "${env:PATH}"
            },
            "console": "internalConsole"
        }
    ]
}
