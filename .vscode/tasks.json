{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build-engine",
            "type": "shell",
            "command": "make",
            "options": {
                "cwd": "${workspaceFolder}/engine"
            },
            "problemMatcher": ["$gcc"],
            "group": "build"
        },
        {
            "label": "build-csharp",
            "type": "shell",
            "command": "dotnet build",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": ["$msCompile"],
            "group": "build",
            "dependsOn": ["build-engine"]
        },
        {
            "label": "build",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "dependsOn": ["build-csharp"]
        }
    ]
}
